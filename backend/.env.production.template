# Production Environment Variables Template
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to version control

# Database Configuration (SQL Server)
DB_TYPE=mssql
DB_SERVER=your-sql-server-host
DB_HOST=your-sql-server-host
DB_PORT=1433
DB_NAME=PRFMonitoringDB
DB_USER=sa
DB_PASSWORD=your-sql-password
DB_ENCRYPT=true
DB_TRUST_CERT=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# Application Configuration
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:9007
CORS_ORIGIN=http://localhost:9007

# LDAP Configuration (optional)
LDAP_URL=ldap://your-ldap-server:389
LDAP_BIND_DN=cn=admin,dc=company,dc=com
LDAP_BIND_PASSWORD=your_ldap_password
LDAP_SEARCH_BASE=ou=users,dc=company,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})

# CIFS Network Share (optional, but required if PRF documents are read from the share)
CIFS_SERVER=your-file-server-host
CIFS_SHARE=your-share-name
CIFS_USERNAME=your-domain-username
CIFS_PASSWORD=your-domain-password
SHARED_FOLDER_PATH=/app/shared-documents
GRAPH_TOKEN_CACHE_PATH=/app/data/token_cache.json

# Settings Encryption
SETTINGS_ENCRYPTION_KEY=your-settings-encryption-key-change-in-production

# Microsoft Graph OneDrive Excel Sync
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
ONEDRIVE_SHARED_EXCEL_LINK=https://example.sharepoint.com/:x:/r/sites/example/Shared%20Documents/PRF.xlsx
ONEDRIVE_WORKSHEET_NAME=PRF Detail

# Pronto Sync
PRONTO_SYNC_ENABLED=true
